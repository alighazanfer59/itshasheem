    "def fetch_all_historical_ohlcv(product_id, granularity, days):\n",
    "    all_candles = []\n",
    "\n",
    "    # Define start time\n",
    "    end_time = datetime.datetime.utcnow()\n",
    "    start_time = end_time - datetime.timedelta(days=days)\n",
    "\n",
    "    while start_time < end_time:\n",
    "        next_end_time = start_time + datetime.timedelta(hours=granularity * 300 // 3600)\n",
    "\n",
    "        # Fetch data\n",
    "        candles = fetch_historical_ohlcv(\n",
    "            product_id, granularity, start_time, next_end_time\n",
    "        )\n",
    "\n",
    "        if candles:\n",
    "            all_candles.extend(candles)\n",
    "\n",
    "        # Move start time forward\n",
    "        start_time = next_end_time\n",
    "        time.sleep(1)  # Coinbase API rate limit\n",
    "\n",
    "    return all_candles\n",
    "\n",
    "\n",
