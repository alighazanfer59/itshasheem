    "# Granularity values in seconds\n",
    "granularity_seconds = [60, 300, 900, 3600, 21600, 86400]\n",
    "\n",
    "# Convert to readable format\n",
    "granularity_readable = []\n",
    "\n",
    "for seconds in granularity_seconds:\n",
    "    if seconds < 3600:  # Less than an hour\n",
    "        granularity_readable.append(f\"{seconds // 60} min\")\n",
    "    elif seconds < 86400:  # Less than a day\n",
    "        granularity_readable.append(f\"{seconds // 3600} hr\")\n",
    "    else:  # A day or more\n",
    "        granularity_readable.append(f\"{seconds // 86400} day\")\n",
    "\n",
    "# Print converted values\n",
    "for sec, readable in zip(granularity_seconds, granularity_readable):\n",
    "    print(f\"{sec} sec -> {readable}\")"
   ]
